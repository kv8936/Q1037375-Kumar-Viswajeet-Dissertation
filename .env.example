# Production environment for docker-compose.prod.yml.
# Copy to .env on the server and fill in real values. NEVER commit .env.
#   cp .env.example .env && nano .env
#
# Generate a strong DB password, e.g.:
#   openssl rand -base64 32 | tr -d '/+=' | cut -c1-32

# --- Public site / TLS ---------------------------------------------------
# The subdomain whose A/AAAA records point at this server.
SITE_ADDRESS=your-subdomain.your-domain.example
# Contact address Let's Encrypt uses for expiry notices. CONFIRM THIS.
CADDY_ACME_EMAIL=your-email@example.com

# --- Database (keep POSTGRES_PASSWORD in sync everywhere) ----------------
# Keep this aligned with the existing database volume's major version.
# For existing long-lived volumes created on PG16, leave this as 16.
POSTGRES_MAJOR=16
POSTGRES_DB=hazard_chatbot
POSTGRES_USER=hazard
POSTGRES_PASSWORD=your-strong-db-password

# --- Application behaviour ----------------------------------------------
PRIVACY_MODE=true
ENABLE_DB_CONTENT_LOGGING=false
MIN_SCENARIO_WORDS=3
MIN_SCENARIO_CHARS=15
RUST_LOG=info

# --- Inference / models --------------------------------------------------
CAPTION_MODEL_NAME=Salesforce/blip-image-captioning-base
PRELOAD_CAPTION_MODEL=true
